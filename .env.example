# Server Configuration
PORT=3000
NODE_ENV=development

# Email Provider Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
GMAIL_USER=your_email@gmail.com
GMAIL_PASS=your_app_password
FROM_EMAIL=Zeeshan@solinovation.com

# Security Configuration
# Update this to your frontend URL in production
ALLOWED_ORIGIN=*

# Rate Limiting
EMAIL_RATE_LIMIT_WINDOW_MS=60000
EMAIL_RATE_LIMIT_MAX_REQUESTS=5

# Firebase Configuration (Service Account)
# Option 1: Provide the path to your service account JSON file
# FIREBASE_SERVICE_ACCOUNT_PATH="./firebase-adminsdk.json"

# Option 2: Provide individual values (Better for Vercel/Heroku)
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
