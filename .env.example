# Server Configuration
PORT=3000
NODE_ENV=development

# Email Provider Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
GMAIL_USER=your_email@gmail.com
GMAIL_PASS=your_app_password
