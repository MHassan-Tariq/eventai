# Security Configuration
# Update this to your frontend URL in production
ALLOWED_ORIGIN=*

# Rate Limiting
EMAIL_RATE_LIMIT_WINDOW_MS=60000
EMAIL_RATE_LIMIT_MAX_REQUESTS=5
